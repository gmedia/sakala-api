{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "sakala/sakala-api",
    "type": "project",
    "description": "API-first control plane for the Sakala open-source deployment platform.",
    "keywords": [
        "sakala",
        "deployment",
        "control-plane",
        "laravel"
    ],
    "license": "Apache-2.0",
    "require": {
        "php": "^8.5",
        "dedoc/scramble": "^0.13",
        "laravel/framework": "^13.8",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.28",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.10",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.62",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan serve"
        ],
        "queue": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan queue:listen --tries=1 --timeout=0"
        ],
        "reverb": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan reverb:start"
        ],
        "logs": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan pail --timeout=0"
        ],
        "lint": "@php vendor/bin/pint --parallel",
        "lint:check": "@php vendor/bin/pint --parallel --test",
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit=1G",
        "docs:analyse": "@php artisan scramble:analyze --no-interaction",
        "docs:export": "@php artisan scramble:export --no-interaction",
        "check": [
            "@lint:check",
            "@analyse",
            "@docs:analyse",
            "@test"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test --compact"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
